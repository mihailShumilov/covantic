# Covantic Production Environment
# Copy to .env on your server and fill in real values
# Usage: cp .env.production.example .env && nano .env

# ── Domain ──
DOMAIN=covantic.org

# ── PostgreSQL ──
POSTGRES_USER=covantic
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=covantic

# ── Solana ──
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
PROGRAM_ID=91TyFjPEKeKevThuZmfvYzFpzHhchVLtPYf5nLiUzoV7

# ── Helius ──
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
# Must be at least 64 chars. Generate: openssl rand -hex 32
HELIUS_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_64_CHARS_MIN

# ── Internal alert bus (Redis `monitoring:alerts` HMAC) ──
# Generate: openssl rand -hex 32
ALERT_HMAC_SECRET=CHANGE_ME_32_OR_MORE_CHARS

# ── Redis ──
# Required. Redis runs with --requirepass; the URL embeds the password.
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ── Oracle ──
ORACLE_KEYPAIR_PATH=./keys/oracle-keypair.json

# ── USDC Mint (devnet) ──
# Mock-USDC mint created by `pnpm --filter api init:protocol`.
USDC_MINT=79yZ9PuqbzzdCp2TriBwL9oxPtdfkhuFAjkSR95oJt1B

# ── Frontend (baked into Next.js at build time) ──
# NEXT_PUBLIC_PROGRAM_ID is wired from ${PROGRAM_ID} in docker-compose.prod.yml
# so you don't need to set it twice.
NEXT_PUBLIC_API_URL=https://covantic.org
NEXT_PUBLIC_WS_URL=wss://covantic.org
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
