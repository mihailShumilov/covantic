{
  "name": "@covantic/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,fleet -c cyan,magenta \"tsx watch src/index.ts\" \"tsx scripts/fleet-start.ts\"",
    "dev:api-only": "tsx watch src/index.ts",
    "dev:fleet": "tsx scripts/fleet-start.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "monitor": "tsx src/workers/monitor-entry.ts",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "init:protocol": "tsx scripts/init-protocol.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "demo:exploit": "tsx scripts/simulate-exploit.ts",
    "demo:run": "tsx scripts/run-demo.ts",
    "test:e2e": "COVANTIC_E2E=1 vitest run tests/e2e.test.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@covantic/shared": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "bullmq": "^5.0.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
