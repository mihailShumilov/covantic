# Covantic — Environment Variables
# Copy to .env and fill in values

# -- Solana --
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Program ID (after anchor deploy)
PROGRAM_ID=YOUR_PROGRAM_ID_AFTER_DEPLOY

# Oracle keypair (JSON secret key file)
# Generate: solana-keygen new -o keys/oracle-keypair.json
ORACLE_KEYPAIR_PATH=./keys/oracle-keypair.json

# -- Helius --
# Get at: https://dev.helius.xyz/
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
# Must be at least 64 chars (generate via: openssl rand -hex 32)
HELIUS_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_64_OR_MORE_CHARS_XXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# HMAC secret for the internal `monitoring:alerts` Redis bus. Any process
# that publishes alerts must share this secret; generate via:
#   openssl rand -hex 32
ALERT_HMAC_SECRET=CHANGE_ME_MIN_32_CHARS_XXXXXXXXXXXXX

# Publicly reachable URL where Helius can deliver webhooks. Used by
# `pnpm webhook:sync` to register the receiver with Helius.
# Local dev: expose port 4099 with ngrok, set to the ngrok https URL.
#   ngrok http 4099
#   WEBHOOK_PUBLIC_URL=https://XXXX-YYY-ZZZ.ngrok-free.app
# Prod: use the real hostname (e.g. https://api.covantic.org)
# Optional — leave unset to skip webhook registration.
WEBHOOK_PUBLIC_URL=

# -- Database --
# Set POSTGRES_PASSWORD first (docker-compose consumes it); this URL uses it.
POSTGRES_USER=covantic
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=covantic
DATABASE_URL=postgresql://covantic:${POSTGRES_PASSWORD}@localhost:5499/covantic

# -- Redis --
# Password used by docker-compose and embedded in REDIS_URL.
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6399

# -- API Server --
PORT=4099
LOG_LEVEL=debug

# -- Frontend --
NEXT_PUBLIC_API_URL=http://localhost:4099
NEXT_PUBLIC_WS_URL=ws://localhost:4099
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NEXT_PUBLIC_PROGRAM_ID=YOUR_PROGRAM_ID_AFTER_DEPLOY
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# -- USDC Mint (devnet) --
# Devnet USDC: test SPL token mint
# Created by setup-local.sh
USDC_MINT=YOUR_DEVNET_USDC_MINT
